{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  // Org-wide Renovate policy for materia-ops.
  //
  // Extend this LAST in each repo's config so it overrides upstream presets:
  //   extends: [
  //     "github>home-operations/renovate-presets#2.1.0",
  //     "github>materia-ops/.github//renovate/default",
  //   ]
  //
  // The org ruleset forbids direct pushes to the default branch (no bypass),
  // so the upstream :automergeBranch preset would be rejected. Force every
  // automerge through a PR that Renovate then auto-merges (0 approvals are
  // required by the ruleset, so this stays hands-off).
  automergeType: "pr",
  platformAutomerge: true,
}
